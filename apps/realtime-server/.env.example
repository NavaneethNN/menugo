# Port the Socket.io server listens on
PORT=4000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# Shared secret — must match INTERNAL_SECRET in apps/api
INTERNAL_SECRET="change-me-to-a-random-secret"

# JWT secret — must match JWT_SECRET in apps/api (used to verify staff tokens)
JWT_SECRET="change-me-to-a-long-random-secret"
