      staffId: payload.staffId,
      name: payload.name,
      role: payload.role,
      kitchenId: payload.kitchenId,
      restaurantId: payload.restaurantId,
    }),
  clearAuth: () =>
    set({
      token: null,
      staffId: null,
      name: null,
      role: null,
      kitchenId: null,
      restaurantId: null,
    }),
}));
