{
  "name": "restaurant-platform",
  "private": true,
  "version": "1.0.0",
  "description": "QR-Based Restaurant Ordering & Fulfillment System — V1 Monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @restaurant/db run generate",
    "db:push": "pnpm --filter @restaurant/db run push",
    "db:migrate": "pnpm --filter @restaurant/db run migrate",
    "db:seed": "pnpm --filter @restaurant/db run seed",
    "db:studio": "pnpm --filter @restaurant/db run studio"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.4.0",
    "prettier": "^3.3.0",
    "@types/node": "^20.14.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
