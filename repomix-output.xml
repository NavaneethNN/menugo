    staffId: string;
    name: string;
    role: StaffRole;
    kitchenId: string | null;
    restaurantId: string;
  }) => void;
  clearAuth: () => void;
}

export const useAuthStore = create<AuthState>((set) => ({
  token: null,
  staffId: null,
  name: null,
  role: null,
  kitchenId: null,
  restaurantId: null,
  setAuth: (payload) =>
    set({
