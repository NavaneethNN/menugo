      "id": "...",
      "name": "Main Course",
      "sortOrder": 0,
      "menuItems": [
        {
          "id": "...",
          "name": "Chicken Biriyani",
          "description": "...",
          "price": "180.00",
          "imageUrl": null,
          "isAvailable": true,
          "kitchenId": "..."
